# ==============================================================
# 3Dream Studios — .gitignore
# Archivos que NO deben subirse al repositorio público de GitHub
# ==============================================================

# ──────────────────────────────────────────────────────────────
# 📋 DOCUMENTOS INTERNOS / ESTRATEGIA
# ──────────────────────────────────────────────────────────────
/actualizar_pagina.bat
/guiaExportacionglb.md
/estrategia.md
/guia_escaneo_alimentos.md
/gitignore
*.log

# ──────────────────────────────────────────────────────────────
# 🖥️ ARCHIVOS DE SISTEMA OPERATIVO
# ──────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ──────────────────────────────────────────────────────────────
# 🛠️ EDITORES / IDEs
# ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# ──────────────────────────────────────────────────────────────
# 📦 DEPENDENCIAS / NODE
# ──────────────────────────────────────────────────────────────
node_modules/
package-lock.json
yarn.lock
.npm
.cache/

# ──────────────────────────────────────────────────────────────
# 🎨 ARCHIVOS FUENTE / BLENDER / ADOBE
# (Los archivos .blend son de producción, NO van al sitio web)
# ──────────────────────────────────────────────────────────────
*.blend
*.blend1
*.blend2
*.psd
*.ai
*.indd
*.sketch
*.fig
*.xd
*.fbx
*.obj
*.mtl
*.stl
*.3ds
*.max
*.ma
*.mb
*.c4d
*.ztl

# ──────────────────────────────────────────────────────────────
# 🖼️ ARCHIVOS NO USADOS EN LA WEB
# (Capturas de pantalla internas, duplicados, borradores)
# ──────────────────────────────────────────────────────────────
assets/renders/Captura de pantalla*
assets/renders/untitled.png
assets/img/logo.jpeg

# ──────────────────────────────────────────────────────────────  
# 🎬 ARCHIVOS DE VIDEO/MEDIA PESADOS TEMPORALES
# (Archivos de producción que no son para la web)
# ──────────────────────────────────────────────────────────────
*.mov
*.avi
*.wmv
*.flv
*.srt
*.ass
*.sub

# ──────────────────────────────────────────────────────────────
# 🔐 SEGURIDAD / SECRETOS
# ──────────────────────────────────────────────────────────────
.env
.env.*
*.key
*.pem
*.cert
config.local.js
secrets.*

# ──────────────────────────────────────────────────────────────
# 🗜️ ARCHIVOS COMPRIMIDOS / TEMPORALES
# ──────────────────────────────────────────────────────────────
*.zip
*.rar
*.7z
*.tar
*.gz
*.bak
*.tmp
*.temp
*.swp
*~

# ──────────────────────────────────────────────────────────────
# 📱 ARCHIVOS DE FOTOGRAMETRÍA / ESCANEO 3D
# (Raw scans - solo los GLB optimizados van al repo)
# ──────────────────────────────────────────────────────────────
*.ply
*.xyz
*.pts
*.e57
*.las
*.laz
*.mind
*.patt
scans/
raw-captures/
